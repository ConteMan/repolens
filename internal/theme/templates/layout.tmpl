{{define "layout"}}<!doctype html>
<html{{if .Lang}} lang="{{.Lang}}"{{end}}>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{{if .NoIndex}}<meta name="robots" content="noindex">{{end}}
<title>{{.Title}} - {{.SiteTitle}}</title>
<link rel="stylesheet" href="{{.RelRoot}}_assets/site.css">
<link rel="stylesheet" href="{{.RelRoot}}_assets/chroma.css">
{{if .VarsCSS}}<style>{{.VarsCSS}}</style>{{end}}
{{if .HasCustomCSS}}<link rel="stylesheet" href="{{.RelRoot}}_assets/custom.css">{{end}}
{{.HeadExtra}}
</head>
<body data-page-kind="{{.Kind}}">
<svg class="icon-sprite" aria-hidden="true" focusable="false">
  <symbol id="icon-folder" viewBox="0 0 16 16"><path d="M1.5 3.5h4l1.4 1.6h7.6v7.4a1 1 0 0 1-1 1h-12a1 1 0 0 1-1-1v-8a1 1 0 0 1 1-1z"/></symbol>
  <symbol id="icon-file" viewBox="0 0 16 16"><path d="M3 1.5h6.5L13 5v9.5H3z"/><path d="M9.5 1.5V5H13"/></symbol>
  <symbol id="icon-markdown" viewBox="0 0 16 16"><path d="M1.5 4h13v8h-13z"/><path d="M3.5 10V6.8L5 8.6l1.5-1.8V10M9 6.8V10M8 9l1 1 1-1"/></symbol>
  <symbol id="icon-html" viewBox="0 0 16 16"><path d="M2 3l1.1 10L8 14.5l4.9-1.5L14 3z"/><path d="M5.5 6.2h5M5.8 8.2h4.4l-.3 2.3L8 11.1l-1.9-.6"/></symbol>
  <symbol id="icon-code" viewBox="0 0 16 16"><path d="M6.2 4.2L3 8l3.2 3.8M9.8 4.2L13 8l-3.2 3.8"/></symbol>
  <symbol id="icon-image" viewBox="0 0 16 16"><path d="M2.5 3.5h11v9h-11z"/><path d="M4 11l3-3 2 2 1.2-1.2L13 11"/><circle cx="10.8" cy="5.8" r=".8"/></symbol>
  <symbol id="icon-binary" viewBox="0 0 16 16"><path d="M3 1.5h10v13H3z"/><path d="M5 5h2v2H5zM9 5h2v2H9zM5 9h2v2H5zM9 9h2v2H9z"/></symbol>
</svg>
<header class="topbar">
  <a class="brand" href="{{.RelRoot}}view/">{{.SiteTitle}}</a>
  <nav class="top-actions" aria-label="Page actions">
    {{if .MirrorHref}}<a class="action-link" href="{{.MirrorHref}}">Raw</a>{{end}}
  </nav>
</header>
<div class="shell">
  <aside class="sidebar" data-tree-scroll>
    <nav class="tree-nav" aria-label="Repository tree">{{template "tree" .Tree}}</nav>
  </aside>
  <main class="content" id="content">
    <nav class="breadcrumbs" aria-label="Breadcrumbs">
      {{range .Breadcrumbs}}{{if .Current}}<span aria-current="page">{{.Label}}</span>{{else}}<a href="{{.Href}}">{{.Label}}</a>{{end}}{{end}}
    </nav>
    <h1>{{.Title}}</h1>
    {{template "page" .}}
    {{if .LastCommit}}<footer class="meta">Last updated {{.LastCommit.Time.Format "2006-01-02 15:04"}} · {{shortHash .LastCommit.Hash}}</footer>{{end}}
  </main>
</div>
{{if .HasMermaid}}<script defer src="{{.RelRoot}}_assets/mermaid.min.js"></script>{{end}}
<script defer src="{{.RelRoot}}_assets/site.js"></script>
</body>
</html>{{end}}
