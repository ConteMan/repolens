{{define "layout"}}<!doctype html>
<html class="no-js"{{if .Lang}} lang="{{.Lang}}"{{end}}>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{{if .NoIndex}}<meta name="robots" content="noindex">{{end}}
<title>{{.Title}} - {{.SiteTitle}}</title>
<script>document.documentElement.className=document.documentElement.className.replace(/\bno-js\b/,"js");</script>
<link rel="stylesheet" href="{{.RelRoot}}_assets/site.css">
<link rel="stylesheet" href="{{.RelRoot}}_assets/chroma.css">
{{if .VarsCSS}}<style>{{.VarsCSS}}</style>{{end}}
{{if .HasCustomCSS}}<link rel="stylesheet" href="{{.RelRoot}}_assets/custom.css">{{end}}
{{.HeadExtra}}
</head>
<body data-page-kind="{{.Kind}}">
<svg class="icon-sprite" aria-hidden="true" focusable="false">
  <symbol id="icon-folder" viewBox="0 0 16 16"><path d="M1.5 3.5h4l1.4 1.6h7.6v7.4a1 1 0 0 1-1 1h-12a1 1 0 0 1-1-1v-8a1 1 0 0 1 1-1z"/></symbol>
  <symbol id="icon-file" viewBox="0 0 16 16"><path d="M3 1.5h6.5L13 5v9.5H3z"/><path d="M9.5 1.5V5H13"/></symbol>
  <symbol id="icon-markdown" viewBox="0 0 16 16"><path d="M3 1.5h6.5L13 5v9.5H3z"/><path d="M9.5 1.5V5H13"/><path d="M5.3 8.2h5.4M5.3 10.7h5.4"/></symbol>
  <symbol id="icon-html" viewBox="0 0 16 16"><path d="M2 3l1.1 10L8 14.5l4.9-1.5L14 3z"/><path d="M5.5 6.2h5M5.8 8.2h4.4l-.3 2.3L8 11.1l-1.9-.6"/></symbol>
  <symbol id="icon-code" viewBox="0 0 16 16"><path d="M6.2 4.2L3 8l3.2 3.8M9.8 4.2L13 8l-3.2 3.8"/></symbol>
  <symbol id="icon-image" viewBox="0 0 16 16"><path d="M2.5 3.5h11v9h-11z"/><path d="M4 11l3-3 2 2 1.2-1.2L13 11"/><circle cx="10.8" cy="5.8" r=".8"/></symbol>
  <symbol id="icon-binary" viewBox="0 0 16 16"><path d="M3 1.5h10v13H3z"/><path d="M5 5h2v2H5zM9 5h2v2H9zM5 9h2v2H5zM9 9h2v2H9z"/></symbol>
  <symbol id="icon-tree" viewBox="0 0 16 16"><path d="M2.5 3.5h11M2.5 8h11M2.5 12.5h11"/></symbol>
  <symbol id="icon-back" viewBox="0 0 16 16"><path d="M9.5 3.5L5 8l4.5 4.5"/></symbol>
  <symbol id="icon-fwd" viewBox="0 0 16 16"><path d="M6.5 3.5L11 8l-4.5 4.5"/></symbol>
  <symbol id="icon-toc" viewBox="0 0 16 16"><path d="M5.5 4h8M5.5 8h8M5.5 12h8"/><circle cx="2.8" cy="4" r=".9"/><circle cx="2.8" cy="8" r=".9"/><circle cx="2.8" cy="12" r=".9"/></symbol>
  <symbol id="icon-minus" viewBox="0 0 16 16"><path d="M3.5 8h9"/></symbol>
  <symbol id="icon-plus" viewBox="0 0 16 16"><path d="M8 3.5v9M3.5 8h9"/></symbol>
  <symbol id="icon-width" viewBox="0 0 16 16"><path d="M2 2.5v11M14 2.5v11M5 8h6M5 8l1.6-1.6M5 8l1.6 1.6M11 8L9.4 6.4M11 8l-1.6 1.6"/></symbol>
  <symbol id="icon-download" viewBox="0 0 16 16"><path d="M8 2.5v7.5M4.8 7l3.2 3 3.2-3M3 13h10"/></symbol>
  <symbol id="icon-search" viewBox="0 0 16 16"><circle cx="7" cy="7" r="4.2"/><path d="M10.2 10.2L14 14"/></symbol>
  <symbol id="icon-info" viewBox="0 0 16 16"><circle cx="8" cy="8" r="5.7"/><path d="M8 7.2V11"/><circle cx="8" cy="5" r=".35"/></symbol>
  <symbol id="icon-commit" viewBox="0 0 16 16"><circle cx="8" cy="8" r="2.2"/><path d="M1.5 8h4.3M10.2 8h4.3"/></symbol>
  <symbol id="icon-pin" viewBox="0 0 16 16"><path d="M6 2.5h4l.5 5 2 2h-9l2-2z"/><path d="M8 9.5V14"/></symbol>
  <symbol id="icon-expand-all" viewBox="0 0 16 16"><path d="M3 2.5h10M4.5 6L8 9.5 11.5 6M3 13.5h10"/></symbol>
  <symbol id="icon-collapse-all" viewBox="0 0 16 16"><path d="M3 2.5h10M4.5 10L8 6.5 11.5 10M3 13.5h10"/></symbol>
  <symbol id="icon-locate" viewBox="0 0 16 16"><circle cx="8" cy="8" r="3.5"/><path d="M8 1.5V4M8 12v2.5M1.5 8H4M12 8h2.5"/></symbol>
</svg>
<header class="topbar">
  <div class="tb-group js-only">
    <button class="tb-btn" id="btn-tree" type="button" title="{{index .UI "tree_title"}}" aria-label="{{index .UI "tree"}}" aria-pressed="false"><svg class="icon" aria-hidden="true"><use href="#icon-tree"></use></svg></button>
    <button class="tb-btn" id="btn-back" type="button" title="{{index .UI "back"}}" aria-label="{{index .UI "back"}}"><svg class="icon" aria-hidden="true"><use href="#icon-back"></use></svg></button>
    <button class="tb-btn" id="btn-fwd" type="button" title="{{index .UI "forward"}}" aria-label="{{index .UI "forward"}}"><svg class="icon" aria-hidden="true"><use href="#icon-fwd"></use></svg></button>
  </div>
  <nav class="tb-crumbs" aria-label="Breadcrumbs">
    {{range .Breadcrumbs}}{{if .Current}}<span class="tb-file" title="{{.Path}}" aria-label="{{.Path}}" aria-current="page">{{.Label}}</span>{{else}}<a href="{{.Href}}" title="{{.Path}}" aria-label="{{.Path}}">{{.Label}}</a>{{end}}{{end}}
  </nav>
  <div class="tb-group">
    {{if and .TOC (eq .TOCPanel "floating")}}<button class="tb-btn js-only" id="btn-toc" type="button" title="{{index .UI "toc_title"}}" aria-label="{{index .UI "toc_title"}}" aria-pressed="false"><svg class="icon" aria-hidden="true"><use href="#icon-toc"></use></svg></button>{{end}}
    {{if and .TOC (eq .TOCPanel "floating")}}<span class="tb-sep js-only"></span>{{end}}
    <button class="tb-btn js-only" id="btn-zoom-out" type="button" title="{{index .UI "zoom_out"}}" aria-label="{{index .UI "zoom_out"}}"><svg class="icon" aria-hidden="true"><use href="#icon-minus"></use></svg></button>
    <span class="zoom-readout js-only" id="zoom-readout">100%</span>
    <button class="tb-btn js-only" id="btn-zoom-in" type="button" title="{{index .UI "zoom_in"}}" aria-label="{{index .UI "zoom_in"}}"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg></button>
    <button class="tb-btn js-only" id="btn-width" type="button" title="{{index .UI "width"}}" aria-label="{{index .UI "width"}}"><svg class="icon" aria-hidden="true"><use href="#icon-width"></use></svg><span id="width-label">{{index .UI "width_default"}}</span></button>
    <span class="tb-sep js-only"></span>
    <span class="info-wrap js-only" id="info-wrap">
      <button class="tb-btn" id="btn-info" type="button" title="{{index .UI "info"}}" aria-label="{{index .UI "info"}}" aria-pressed="false" aria-haspopup="dialog"><svg class="icon" aria-hidden="true"><use href="#icon-info"></use></svg></button>
      <div class="info-panel" role="dialog" aria-label="{{index .UI "info"}}">
        <div class="info-row"><span>{{index .UI "path"}}</span><code data-page-path>{{.RepoPath}}</code></div>
        <div class="info-row"><span>{{index .UI "type"}}</span><b>{{.KindLabel}}</b></div>
        {{if .FileSize}}<div class="info-row"><span>{{index .UI "size"}}</span><b>{{formatSize .FileSize false}}</b></div>{{end}}
        {{if .LastCommit}}<div class="info-row"><span>{{index .UI "last_updated"}}</span><b>{{formatInfoDate .LastCommit}}</b></div>
        <div class="info-row"><span>{{index .UI "commit"}}</span><span class="info-commit"><svg class="icon" aria-hidden="true"><use href="#icon-commit"></use></svg><code>{{shortHash7 .LastCommit.Hash}}</code>{{if .LastCommit.Subject}}<small>{{.LastCommit.Subject}}</small>{{end}}</span></div>{{end}}
        <div class="info-actions">{{if .MirrorHref}}<a href="{{.MirrorHref}}">{{index .UI "view_raw"}}</a>{{end}}{{if .RepoPath}}<a href="#" id="info-copy">{{index .UI "copy_path"}}</a>{{end}}</div>
      </div>
    </span>
    {{if .SourceHref}}<a class="tb-btn" id="btn-source" href="{{.SourceHref}}" title="{{if or (eq .Kind "markdown-source") (eq .Kind "html-source")}}{{index .UI "return_rendered"}}{{else}}{{index .UI "source"}}{{end}}" aria-label="{{if or (eq .Kind "markdown-source") (eq .Kind "html-source")}}{{index .UI "return_rendered"}}{{else}}{{index .UI "source"}}{{end}}"><svg class="icon" aria-hidden="true"><use href="#icon-code"></use></svg></a>{{end}}
    {{if .MirrorHref}}<span class="dl-wrap" id="dl-wrap">
      <button class="tb-btn js-only" id="btn-dl" type="button" title="{{index .UI "download"}}" aria-label="{{index .UI "download"}}" aria-haspopup="menu" aria-expanded="false"><svg class="icon" aria-hidden="true"><use href="#icon-download"></use></svg></button>
      <span class="dl-menu">
        <a href="{{.MirrorHref}}" download><svg class="icon" aria-hidden="true"><use href="#icon-{{iconName .Kind false}}"></use></svg>{{index .UI "download_raw"}} {{baseName .RepoPath}}{{if .FileSize}}<small>{{formatSize .FileSize false}}</small>{{end}}</a>
      </span>
    </span>
    <noscript><a class="tb-btn" href="{{.MirrorHref}}" download title="{{index .UI "download"}}" aria-label="{{index .UI "download"}}"><svg class="icon" aria-hidden="true"><use href="#icon-download"></use></svg></a></noscript>{{end}}
    {{if .SearchEnabled}}<button class="tb-btn js-only" id="btn-search" type="button" title="{{index .UI "search"}}" aria-label="{{index .UI "search"}}"><svg class="icon" aria-hidden="true"><use href="#icon-search"></use></svg></button>{{end}}
  </div>
</header>
<div class="shell">
  <aside class="sidebar" data-tree-scroll>
    <nav class="tree-nav" id="tree-src" aria-label="{{index .UI "tree"}}">
      {{template "tree-actions" .}}
      {{template "tree" .Tree}}
    </nav>
  </aside>
  <main class="content" id="content">
    <h1>{{.Title}}</h1>
    {{template "page" .}}
  </main>
</div>
<div class="scrim" id="scrim" aria-hidden="true"></div>
{{if .SearchEnabled}}<div class="search-modal" id="search-modal" role="dialog" aria-label="{{index .UI "search_label"}}" data-search-label="{{index .UI "search_label"}}" data-search-root="{{.RelRoot}}" data-search-src="{{.RelRoot}}search.json" data-search-placeholder="{{index .UI "search_placeholder"}}" data-search-intro="{{index .UI "search_intro"}}" data-search-empty="{{index .UI "search_empty"}}" data-search-unavailable="{{index .UI "search_unavailable"}}" data-search-files="{{index .UI "search_files"}}" data-search-headings="{{index .UI "search_headings"}}" data-search-select="{{index .UI "search_select"}}" data-search-open="{{index .UI "search_open"}}" data-search-escape="{{index .UI "search_escape"}}">
  <input class="search-input" id="search-input" type="text" placeholder="{{index .UI "search_placeholder"}}" autocomplete="off">
  <div class="search-results" id="search-results"><div class="search-empty">{{index .UI "search_intro"}}</div></div>
  <div class="search-foot"><span><kbd>↑</kbd><kbd>↓</kbd> {{index .UI "search_select"}}</span><span><kbd>Enter</kbd> {{index .UI "search_open"}}</span><span><kbd>Esc</kbd> {{index .UI "search_escape"}}</span></div>
</div>{{end}}
<div class="overlay" id="tree-overlay" role="dialog" aria-label="{{index .UI "tree"}}">
  <div class="overlay-head">
    <span>{{.SiteTitle}} · {{index .UI "tree"}}</span>
    <button class="tb-btn" id="btn-pin-tree" type="button" title="{{index .UI "pin_tree_title"}}"><svg class="icon" aria-hidden="true"><use href="#icon-pin"></use></svg>{{index .UI "pin_tree"}}</button>
  </div>
  <nav class="overlay-tree" id="overlay-tree" data-tree-scroll aria-label="{{index .UI "tree"}}"></nav>
</div>
{{if and .TOC (eq .TOCPanel "floating")}}<aside class="toc-panel" id="toc-panel" aria-label="{{index .UI "toc_title"}}">
  <div class="toc-panel-head">{{index .UI "toc"}}</div>
  <div class="toc-panel-body" id="toc-body">{{range .TOC}}{{template "toc-panel-item" .}}{{end}}</div>
</aside>{{end}}
{{if .HasMermaid}}<script defer src="{{.RelRoot}}_assets/mermaid.min.js"></script>{{end}}
<script defer src="{{.RelRoot}}_assets/site.js"></script>
</body>
</html>{{end}}

{{define "toc-panel-item"}}<a href="#{{.Anchor}}" data-lv="{{.Level}}">{{.Title}}</a>{{range .Children}}{{template "toc-panel-item" .}}{{end}}{{end}}

{{define "tree-actions"}}<div class="tree-actions js-only" role="group" aria-label="{{index .UI "tree_actions"}}">
  <button class="tree-action" type="button" data-tree-action="expand" title="{{index .UI "tree_expand_all"}}" aria-label="{{index .UI "tree_expand_all"}}"><svg class="icon" aria-hidden="true"><use href="#icon-expand-all"></use></svg></button>
  <button class="tree-action" type="button" data-tree-action="collapse" title="{{index .UI "tree_collapse_all"}}" aria-label="{{index .UI "tree_collapse_all"}}"><svg class="icon" aria-hidden="true"><use href="#icon-collapse-all"></use></svg></button>
  <button class="tree-action" type="button" data-tree-action="locate" title="{{index .UI "tree_locate_current"}}" aria-label="{{index .UI "tree_locate_current"}}"><svg class="icon" aria-hidden="true"><use href="#icon-locate"></use></svg></button>
</div>{{end}}
